# Evolution API Configuration (set these in EasyPanel)
EVOLUTION_API_URL="https://your-easypanel-domain"
EVOLUTION_API_INSTANCE_NAME="fulltech"
EVOLUTION_API_KEY="REPLACE_ME"

# Número del dueño que recibirá las solicitudes (RD). Puedes ponerlo con o sin código país.
EVOLUTION_OWNER_NUMBER="8295319442"

# Admin credentials (recommended)
# ADMIN_USERNAME="fulltechsd@gmail.com"
# ADMIN_PASSWORD="REPLACE_ME"

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=REPLACE_ME
PG_DATABASE=fullpos_sistema
PG_SSLMODE=disable

# Optional convenience
# DATABASE_URL=postgres://user:pass@host:5432/db?sslmode=disable

# ==========================================
# PayPal SaaS Billing Configuration
# ==========================================
# Never commit real PayPal credentials.
# Set these in EasyPanel environment variables.

# PayPal mode: "sandbox" or "live"
# Supports both PAYPAL_ENV and PAYPAL_MODE (PAYPAL_ENV takes precedence)
PAYPAL_ENV=sandbox
# PAYPAL_MODE=sandbox

# Optional: override base URL (useful for testing with custom endpoints)
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# PayPal API credentials (get from https://developer.paypal.com/dashboard/applications)
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_CLIENT_SECRET=REPLACE_ME
# Optional legacy alias supported by the backend:
# PAYPAL_SECRET=REPLACE_ME

# Brand name shown in PayPal checkout
PAYPAL_BRAND_NAME="Appyra"

# Return URLs after PayPal payment
# These must be publicly accessible URLs
PAYPAL_RETURN_URL=https://your-domain.com/paypal/success
PAYPAL_CANCEL_URL=https://your-domain.com/paypal/cancel

# Webhook ID for PayPal webhook signature verification (optional for now)
# PAYPAL_WEBHOOK_ID=

# App URL (used for internal redirects)
# APP_URL=https://your-domain.com
