# EasyPanel example environment variables (SAFE TEMPLATE)
# Replace values in your EasyPanel environment settings.

EVOLUTION_API_URL=https://YOUR-EASYPANEL-HOST
EVOLUTION_API_INSTANCE_NAME=fulltech
EVOLUTION_API_KEY=REPLACE_ME
EVOLUTION_OWNER_NUMBER=REPLACE_ME

ADMIN_USERNAME=REPLACE_ME
ADMIN_PASSWORD=REPLACE_ME

PG_HOST=YOUR_PG_HOST
PG_PORT=5432
PG_USER=REPLACE_ME
PG_PASSWORD=REPLACE_ME
PG_DATABASE=REPLACE_ME
PG_SSLMODE=disable

# Optional (preferred if your app supports it):
DATABASE_URL=postgres://REPLACE_ME:REPLACE_ME@YOUR_PG_HOST:5432/REPLACE_ME?sslmode=disable

PAYPAL_MODE=sandbox
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=REPLACE_ME
PAYPAL_SECRET=REPLACE_ME
# Live mode:
# PAYPAL_MODE=live
# PAYPAL_BASE_URL=https://api-m.paypal.com
PAYPAL_WEBHOOK_ID=REPLACE_ME
PAYPAL_BRAND_NAME=FULLTECH POS
PAYPAL_RETURN_URL=https://YOUR-EASYPANEL-HOST/paypal/success
PAYPAL_CANCEL_URL=https://YOUR-EASYPANEL-HOST/paypal/cancel
